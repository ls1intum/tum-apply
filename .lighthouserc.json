{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "onlyCategories": ["accessibility"],
        "chromeFlags": "--no-sandbox --headless --disable-gpu"
      },
      "puppeteerScript": "./lighthouse-auth.js"
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error",
        {
          "minScore": 0.6
        }
      ]
      }
    }
  }
}
