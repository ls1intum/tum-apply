changed_files=$(git diff --name-only HEAD @{push} 2>/dev/null || git diff --name-only HEAD~1)

client_changed=$(echo "$changed_files" | grep -E "^src/main/(webapp|generated)|webpack/|package\.json" || true)
server_changed=$(echo "$changed_files" | grep -E "^src/(main|test)/java/" || true)

if [ -n "$client_changed" ]; then
  echo "Client changes detected — running lint:fix and prettier..."
  npm run lint:fix
  npx prettier --write "{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,js,cjs,mjs,ts,cts,mts,java,html,css,scss}"
fi

if [ -n "$server_changed" ]; then
  echo "Server changes detected — running spotlessApply..."
  ./gradlew spotlessApply
fi

if ! git diff --quiet; then
  echo "ERROR: Formatting tools made changes. Please review, stage, and commit them before pushing."
  exit 1
fi

branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ] || [ "$branch" = "develop" ]; then
  exit 0
fi

if ! echo "$branch" | grep -qE "^(chore|feat|test|bugfix|general)/"; then
  echo "ERROR: Branch '$branch' does not follow naming convention."
  echo "Use one of: chore/ feat/ test/ bugfix/ general/"
  exit 1
fi
