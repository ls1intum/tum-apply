<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!--
    Tables for in-app WebAuthn (passkeys), consumed by Spring Security's
    JdbcPublicKeyCredentialUserEntityRepository and JdbcUserCredentialRepository.
    Column names are fixed by those repositories. Id columns use VARCHAR(512) (base64url) so the
    primary keys stay within MySQL's index key-length limit (unlike the reference schema's VARCHAR(1000)).
  -->
  <changeSet id="047a_create_user_entities" author="krusche">
    <createTable tableName="user_entities">
      <column name="id" type="VARCHAR(512)">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="display_name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="047b_create_user_credentials" author="krusche">
    <createTable tableName="user_credentials">
      <column name="credential_id" type="VARCHAR(512)">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="user_entity_user_id" type="VARCHAR(512)">
        <constraints nullable="false"/>
      </column>
      <column name="public_key" type="BLOB">
        <constraints nullable="false"/>
      </column>
      <column name="signature_count" type="BIGINT"/>
      <column name="uv_initialized" type="BOOLEAN"/>
      <column name="backup_eligible" type="BOOLEAN"/>
      <column name="authenticator_transports" type="VARCHAR(1000)"/>
      <column name="public_key_credential_type" type="VARCHAR(100)"/>
      <column name="backup_state" type="BOOLEAN"/>
      <column name="attestation_object" type="BLOB"/>
      <column name="attestation_client_data_json" type="BLOB"/>
      <column name="created" type="TIMESTAMP(3)"/>
      <column name="last_used" type="TIMESTAMP(3)"/>
      <column name="label" type="VARCHAR(1000)">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <createIndex tableName="user_credentials" indexName="idx_user_credentials_user_entity">
      <column name="user_entity_user_id"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>
