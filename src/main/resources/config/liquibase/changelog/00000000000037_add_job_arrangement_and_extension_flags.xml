<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="037a_add_start_date_by_arrangement_to_jobs" author="aniruddh">
    <preConditions onFail="MARK_RAN">
      <not>
        <columnExists tableName="jobs" columnName="start_date_by_arrangement"/>
      </not>
    </preConditions>
    <addColumn tableName="jobs">
      <column name="start_date_by_arrangement" type="boolean" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
    </addColumn>
  </changeSet>

  <changeSet id="037b_add_contract_extendable_to_jobs" author="aniruddh">
    <preConditions onFail="MARK_RAN">
      <not>
        <columnExists tableName="jobs" columnName="contract_extendable"/>
      </not>
    </preConditions>
    <addColumn tableName="jobs">
      <column name="contract_extendable" type="boolean" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
    </addColumn>
  </changeSet>

</databaseChangeLog>
