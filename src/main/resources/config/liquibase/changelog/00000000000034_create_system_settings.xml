<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="00000000000034-1" author="system">
    <comment>Create system_settings table for system-wide configuration (AI feature toggle etc.)</comment>
    <createTable tableName="system_settings">
      <column name="setting_key" type="varchar(255)">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="setting_value" type="varchar(1000)"/>
    </createTable>
  </changeSet>

  <changeSet id="00000000000034-2" author="system">
    <comment>Insert default AI enabled setting</comment>
    <insert tableName="system_settings">
      <column name="setting_key" value="ai.enabled"/>
      <column name="setting_value" value="true"/>
    </insert>
  </changeSet>

</databaseChangeLog>
