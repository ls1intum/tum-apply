<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="033a_add_gender_bias_score_to_jobs" author="melissa">
    <addColumn tableName="jobs">
      <column name="gender_bias_score" type="integer"/>
    </addColumn>
  </changeSet>

  <changeSet id="033b_add_compliance_analysis_json_to_jobs" author="melissa">
    <createTable tableName="job_compliance_issues">
      <column name="job_id" type="CHAR(36)">
        <constraints nullable="false" foreignKeyName="fk_compliance_issues_job" references="jobs(job_id)" deleteCascade="true"/>
      </column>
      <column name="id" type="varchar(255)"/>
      <column name="category" type="varchar(50)"/>
      <column name="text" type="text"/>
      <column name="article" type="varchar(255)"/>
      <column name="explanation" type="text"/>
      <column name="action" type="varchar(50)"/>
      <column name="language" type="varchar(10)"/>
    </createTable>
  </changeSet>

</databaseChangeLog>
