<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="040a_add_reference_letters_required_to_jobs" author="Cathy">
    <addColumn tableName="jobs">
      <column name="reference_letters_required" type="INT" defaultValueNumeric="0">
        <constraints nullable="false"/>
      </column>
    </addColumn>
  </changeSet>

  <changeSet id="040b_create_reference_request_table" author="Cathy">
    <createTable tableName="reference_requests">
      <column name="reference_request_id" type="CHAR(36)">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="application_id" type="CHAR(36)">
        <constraints nullable="false"/>
      </column>

      <column name="title" type="VARCHAR(32)"/>

      <column name="first_name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>

      <column name="last_name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>

      <column name="email" type="VARCHAR(320)">
        <constraints nullable="false"/>
      </column>

      <column name="token_hash" type="VARCHAR(255)"/>

      <column name="token_expires_at" type="DATETIME(3)"/>

      <column name="status" type="VARCHAR(32)" defaultValue="REQUESTED">
        <constraints nullable="false"/>
      </column>

      <column name="created_at" type="DATETIME(3)" defaultValueComputed="CURRENT_TIMESTAMP(3)">
        <constraints nullable="false"/>
      </column>

      <column name="last_modified_at" type="DATETIME(3)" defaultValueComputed="CURRENT_TIMESTAMP(3)">
        <constraints nullable="false"/>
      </column>

      <column name="last_reminder_at" type="DATETIME(3)"/>

      <column name="reminder_count" type="INT" defaultValueNumeric="0">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint baseTableName="reference_requests"
                             baseColumnNames="application_id"
                             referencedTableName="applications"
                             referencedColumnNames="application_id"
                             constraintName="fk_reference_requests_application"
                             onDelete="CASCADE"/>

    <createIndex indexName="idx_reference_requests_application" tableName="reference_requests">
      <column name="application_id"/>
    </createIndex>

    <sql>
      ALTER TABLE reference_requests
        MODIFY last_modified_at DATETIME(3) NOT NULL
        DEFAULT CURRENT_TIMESTAMP(3)
        ON UPDATE CURRENT_TIMESTAMP(3);
    </sql>
  </changeSet>

</databaseChangeLog>
