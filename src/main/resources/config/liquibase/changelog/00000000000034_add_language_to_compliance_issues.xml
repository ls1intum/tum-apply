<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="034_add_language_to_compliance_issues" author="melissa">
    <preConditions onFail="MARK_RAN">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*)
        FROM INFORMATION_SCHEMA.COLUMNS
        WHERE LOWER(TABLE_NAME) = 'job_compliance_issues'
          AND LOWER(COLUMN_NAME) = 'language'
          AND TABLE_SCHEMA = DATABASE()
      </sqlCheck>
    </preConditions>
    <addColumn tableName="job_compliance_issues">
      <column name="language" type="varchar(5)"/>
    </addColumn>
  </changeSet>

</databaseChangeLog>
