<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="035_create_documents_v2_table" author="aniruddh">
    <!--
      New unified documents table using Single Table Inheritance.
      Replaces the legacy `document` + `document_dictionary` two-table model.

      During the migration window this table coexists with the legacy tables.
      In the final migration session, the legacy tables are dropped and this
      table is renamed to `documents`.
    -->
    <createTable tableName="documents_v2">
      <column name="document_id" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true"/>
      </column>
      <column name="doc_owner_type" type="VARCHAR(32)">
        <constraints nullable="false"/>
      </column>
      <column name="document_type" type="VARCHAR(64)">
        <constraints nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(512)">
        <constraints nullable="false"/>
      </column>
      <column name="path" type="VARCHAR(512)">
        <constraints nullable="false"/>
      </column>
      <column name="mime_type" type="VARCHAR(128)">
        <constraints nullable="false"/>
      </column>
      <column name="size_bytes" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="uploaded_by" type="CHAR(36)">
        <constraints nullable="false"/>
      </column>
      <column name="applicant_id" type="CHAR(36)"/>
      <column name="application_id" type="CHAR(36)"/>
      <column name="created_at" type="DATETIME(3)" defaultValueComputed="CURRENT_TIMESTAMP(3)">
        <constraints nullable="false"/>
      </column>
      <column name="last_modified_at" type="DATETIME(3)" defaultValueComputed="CURRENT_TIMESTAMP(3)">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint baseTableName="documents_v2"
                             baseColumnNames="uploaded_by"
                             constraintName="fk_documents_v2_user"
                             referencedTableName="users"
                             referencedColumnNames="user_id"
                             onDelete="CASCADE"/>

    <addForeignKeyConstraint baseTableName="documents_v2"
                             baseColumnNames="applicant_id"
                             constraintName="fk_documents_v2_applicant"
                             referencedTableName="applicants"
                             referencedColumnNames="user_id"
                             onDelete="CASCADE"/>

    <addForeignKeyConstraint baseTableName="documents_v2"
                             baseColumnNames="application_id"
                             constraintName="fk_documents_v2_application"
                             referencedTableName="applications"
                             referencedColumnNames="application_id"
                             onDelete="CASCADE"/>

    <createIndex indexName="idx_documents_v2_applicant" tableName="documents_v2">
      <column name="applicant_id"/>
    </createIndex>

    <createIndex indexName="idx_documents_v2_application" tableName="documents_v2">
      <column name="application_id"/>
    </createIndex>

    <createIndex indexName="idx_documents_v2_path" tableName="documents_v2">
      <column name="path"/>
    </createIndex>

    <sql>
      ALTER TABLE documents_v2 MODIFY last_modified_at DATETIME(3) NOT NULL DEFAULT CURRENT_TIMESTAMP(3) ON UPDATE CURRENT_TIMESTAMP(3);
    </sql>

    <!--
      Discriminator XOR constraint: every row must reference exactly one owner that matches its discriminator.
    -->
    <sql>
      ALTER TABLE documents_v2
      ADD CONSTRAINT chk_documents_v2_owner_xor
      CHECK (
        (doc_owner_type = 'APPLICANT' AND applicant_id IS NOT NULL AND application_id IS NULL)
        OR
        (doc_owner_type = 'APPLICATION' AND application_id IS NOT NULL AND applicant_id IS NULL)
      );
    </sql>
  </changeSet>

</databaseChangeLog>
