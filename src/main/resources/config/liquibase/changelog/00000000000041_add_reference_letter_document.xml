<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="041a_add_document_id_to_reference_requests" author="Cathy">
    <addColumn tableName="reference_requests">
      <column name="document_id" type="CHAR(36)"/>
    </addColumn>

    <addForeignKeyConstraint baseTableName="reference_requests"
                             baseColumnNames="document_id"
                             referencedTableName="documents"
                             referencedColumnNames="document_id"
                             constraintName="fk_reference_requests_document"
                             onDelete="SET NULL"/>

    <createIndex indexName="idx_reference_requests_document" tableName="reference_requests">
      <column name="document_id"/>
    </createIndex>
  </changeSet>

  <changeSet id="041b_add_references_pending_to_application_state" author="Cathy">
    <sql>
      ALTER TABLE applications
        MODIFY application_state ENUM(
        'SAVED', 'SENT', 'REFERENCES_PENDING', 'ACCEPTED', 'IN_REVIEW', 'REJECTED',
        'WITHDRAWN', 'JOB_CLOSED', 'JOB_CLOSED_DRAFT', 'INTERVIEW'
        ) NOT NULL;
    </sql>
  </changeSet>

</databaseChangeLog>
