<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="032a_add_gender_bias_score_to_jobs" author="melissa">
    <preConditions onFail="MARK_RAN">
      <tableExists tableName="jobs"/>
      <not>
        <columnExists tableName="jobs" columnName="gender_bias_score"/>
      </not>
    </preConditions>
    <addColumn tableName="jobs">
      <column name="gender_bias_score" type="integer"/>
    </addColumn>
  </changeSet>

  <changeSet id="032b_add_compliance_analysis_json_to_jobs" author="melissa">
    <preConditions onFail="MARK_RAN">
      <tableExists tableName="jobs"/>
      <not>
        <columnExists tableName="jobs" columnName="compliance_analysis_json"/>
      </not>
    </preConditions>
    <addColumn tableName="jobs">
      <column name="compliance_analysis_json" type="json"/>
    </addColumn>
  </changeSet>

</databaseChangeLog>
