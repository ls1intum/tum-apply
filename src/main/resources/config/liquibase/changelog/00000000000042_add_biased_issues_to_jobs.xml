<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="042_add_biased_issues_to_jobs" author="melissa">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="job_biased_issues"/>
      </not>
    </preConditions>
    <createTable tableName="job_biased_issues">
      <column name="job_id" type="CHAR(36)">
        <constraints nullable="false" foreignKeyName="fk_biased_issues_job" references="jobs(job_id)" deleteCascade="true"/>
      </column>
      <column name="language" type="varchar(10)"/>
      <column name="word" type="varchar(255)"/>
      <column name="type" type="varchar(50)"/>
    </createTable>
  </changeSet>

  <changeSet id="042b_add_unique_constraint_biased_issues" author="aniruddh">
    <addUniqueConstraint
      tableName="job_biased_issues"
      columnNames="job_id, language, word, type"
      constraintName="uk_biased_issues_job_lang_word_type"/>
  </changeSet>

</databaseChangeLog>
