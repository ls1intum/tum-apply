<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="031_create_applicant_subject_area_subscriptions" author="celine">
    <createTable tableName="applicant_subject_area_subscriptions">
      <column name="user_id" type="CHAR(36)">
        <constraints nullable="false"/>
      </column>
      <column name="subject_area" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
    </createTable>

    <addForeignKeyConstraint baseColumnNames="user_id"
                             baseTableName="applicant_subject_area_subscriptions"
                             constraintName="fk_applicant_subscriptions_user"
                             referencedColumnNames="user_id"
                             referencedTableName="applicants"
                             onDelete="CASCADE"/>

    <addUniqueConstraint tableName="applicant_subject_area_subscriptions"
                         columnNames="user_id, subject_area"
                         constraintName="uc_applicant_subject_area"/>
  </changeSet>

</databaseChangeLog>
