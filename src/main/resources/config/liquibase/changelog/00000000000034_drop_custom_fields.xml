<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="034a_cleanup_orphan_custom_field_answer_documents" author="aniruddh">
    <sql>
      DELETE FROM document_dictionary
      WHERE custom_field_answer_id IS NOT NULL
        AND applicant_id IS NULL
        AND application_id IS NULL;
    </sql>
  </changeSet>

  <changeSet id="034b_drop_single_owner_check_constraint" author="aniruddh">
    <sql>
      ALTER TABLE document_dictionary
      DROP CONSTRAINT chk_document_dictionary_exactly_one_owner;
    </sql>
  </changeSet>

  <changeSet id="034c_drop_document_dictionary_custom_field_answer_link" author="aniruddh">
    <dropForeignKeyConstraint baseTableName="document_dictionary"
                              constraintName="fk_document_dictionary_custom_field_answer"/>
    <dropIndex indexName="idx_document_dictionary_custom_field_answer_id"
               tableName="document_dictionary"/>
    <dropColumn tableName="document_dictionary" columnName="custom_field_answer_id"/>
  </changeSet>

  <changeSet id="034d_recreate_single_owner_check_constraint" author="aniruddh">
    <sql>
      ALTER TABLE document_dictionary
      ADD CONSTRAINT chk_document_dictionary_exactly_one_owner
      CHECK (
        (applicant_id IS NOT NULL AND application_id IS NULL)
        OR (applicant_id IS NULL AND application_id IS NOT NULL)
      );
    </sql>
  </changeSet>

  <changeSet id="034e_drop_custom_field_answers_table" author="aniruddh">
    <dropTable tableName="custom_field_answers"/>
  </changeSet>

  <changeSet id="034f_drop_custom_fields_table" author="aniruddh">
    <dropTable tableName="custom_fields"/>
  </changeSet>

</databaseChangeLog>
